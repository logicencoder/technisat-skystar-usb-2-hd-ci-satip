# SkyStar Sat>IP — configuration (copy to config.env and edit)
# All paths are relative to REPO_ROOT unless absolute.

# Where this repo is cloned (auto-detected by scripts if empty)
# REPO_ROOT=/opt/technisat-skystar-satip-minisatip-dvbviewer-ubuntu

# minisatip install/build directory (inside repo by default)
SATIP_DIR="${REPO_ROOT}/minisatip"

# TBS media_build backup location (must NOT stay under /lib/modules/.../updates/)
BACKUP_DIR="${REPO_ROOT}/backup"

# DVB adapter index for SkyStar (always 0 for 14f7:0001 single tuner)
MINISATIP_ADAPTER=0

# Network (auto-detected from default route if SATIP_BIND_IP empty)
SATIP_BIND_IP=
SATIP_RTSP_PORT=8554
SATIP_HTTP_PORT=8080

# LNB / satellite (Astra 23.5°E example)
SATIP_LNB="*:9750-10600-11700"

# Optional: docker container that holds the tuner (leave empty if none)
TUNER_HOLD_DOCKER=le_hscr_sigint

# Optional: USM path on enigma2 server (leave empty on new servers — use systemd instead)
USM_PATH=

# Optional: path to sudo password file for non-interactive sudo (NOT recommended in git)
# SUDO_PASSWORD_FILE=
